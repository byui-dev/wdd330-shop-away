<%- include('partials/header') %>

<div class="page-content"> 
  <h2>Products</h2>

  <div class="product-grid">
    <% products.forEach(product => { %>
      <div class="product-card">
        <img src="<%= product.images[0]?.src %>" alt="<%= product.title %>" />
        <p class="product-title"><%= product.title %></p>
        <p class="product-price"><%=currencySymbol %><%= product.convertedPrice %></p> 
        <a href="/shopify/product/<%= product.id %>">View Details</a>
      </div>
    <% }) %>
  </div>

<div class="pagination">
  <% if (currentPage> 1) { %>
    <a href="?page=<%= currentPage - 1 %>">Previous</a>
    <% } %>

      <% for (let i=1; i <=totalPages; i++) { %>
        <a href="?page=<%= i %>" <%=i===currentPage ? 'class="active"' : '' %>><%= i %></a>
        <% } %>

          <% if (currentPage < totalPages) { %>
            <a href="?page=<%= currentPage + 1 %>">Next</a>
            <% } %>
</div>

<script>
  document.querySelectorAll(".product-card").forEach(card => {
    card.addEventListener("click", function() {
      document.querySelectorAll(".product-card").forEach(c => c.classList.remove("card-selected"));
      this.classList.add("card-selected");
    });
  });
</script>

<div class="page-content">
  <h3>Recently Viewed</h3>
  <div class="product-grid" id="recently-viewed"></div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const recentlyViewed = JSON.parse(localStorage.getItem("recentlyViewed")) || [];
    const container = document.getElementById("recently-viewed");

    if (recentlyViewed.length === 0) {
      container.closest(".page-content").style.display = "none";
      return;
    }

    recentlyViewed.forEach(product => {
      const card = document.createElement("div");
      card.classList.add("product-card");
      card.innerHTML = `
        <img src="${product.image}" alt="${product.title}" />
        <p class="product-title">${product.title}</p>
        <p class="product-price">${product.symbol}${product.price}</p>
        <a href="${product.url}">View Details</a>
      `;
      container.appendChild(card);
    });
  });
</script>

<%- include('partials/footer') %>